{
  "name": "pi-claude-bridge",
  "version": "0.6.2-omp.1",
  "private": false,
  "description": "Pi extension that uses Claude Code (via Agent SDK) as a model provider and adds an AskClaude tool. OMP-patched local build.",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "claude-code",
    "claude-agent-sdk"
  ],
  "author": "Eli Dickinson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elidickinson/pi-claude-bridge.git"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "assets"
  ],
  "scripts": {
    "test:unit": "node --import tsx --test tests/unit-*.mjs",
    "test": "set -a && [ -f .env.test ] && . .env.test; set +a && npm run test:unit && tests/int-smoke.sh && tests/int-multi-turn.sh && tests/int-cache.sh && node --import tsx --test tests/int-*.mjs",
    "test:usage": "tests/usage-test.sh",
    "typecheck": "tsc --noEmit"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.141",
    "@anthropic-ai/sdk": "^0.73.0",
    "cc-session-io": "^0.3.1",
    "change-case": "^5.4.4",
    "@oh-my-pi/pi-ai": "16.3.15",
    "@oh-my-pi/pi-coding-agent": "16.3.15",
    "@oh-my-pi/pi-tui": "16.3.15",
    "@oh-my-pi/pi-catalog": "16.3.15"
  },
  "peerDependencies": {
    "@oh-my-pi/pi-ai": ">=16.3.15",
    "@oh-my-pi/pi-coding-agent": ">=16.3.15",
    "@oh-my-pi/pi-tui": ">=16.3.15"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "@oh-my-pi/pi-ai": "^16.3.15",
    "@oh-my-pi/pi-coding-agent": "^16.3.15",
    "@oh-my-pi/pi-tui": "^16.3.15",
    "@oh-my-pi/pi-catalog": "^16.3.15"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
